<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#eef3fb"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnBackDetalle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_revert"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalle del Reporte"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#182230"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tvDetalleTitulo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#182230"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDetalleDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#475569"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvDetalleTimestamp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#94A3B8"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnEnProceso"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Marcar en proceso"
        android:backgroundTint="#f59e0b"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnResolver"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Marcar como resuelto"
        android:backgroundTint="#16a34a"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnEditar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Editar reporte"
        android:backgroundTint="#2563eb"
        android:textColor="#ffffff"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnEliminar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Eliminar reporte"
        android:backgroundTint="#ef4444"
        android:textColor="#ffffff"/>
</LinearLayout>